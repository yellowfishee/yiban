    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^1.6.0",
    "typescript": "^5.2.2",
    "vitest": "^1.6.0"
  }
}
